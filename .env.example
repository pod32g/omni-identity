# Copy to .env next to docker-compose.yml and adjust.

# Host address/port to publish on. Keep loopback when using a local reverse
# proxy; set OMNI_IDENTITY_BIND_ADDR=0.0.0.0 only for intentional direct access.
OMNI_IDENTITY_BIND_ADDR=127.0.0.1
OMNI_IDENTITY_HOST_PORT=8081

# Public base URL clients (Jellyfin, Omni Metrics/Logging) use to reach this
# server. This is also the OIDC issuer, so it must be stable.
OMNI_SERVER_PUBLIC_URL=https://identity.omni.local

# Override the issuer only if it must differ from the public URL (rare).
OMNI_SECURITY_ISSUER=

# Required for first-run setup when the public URL is not loopback. Generate a
# one-time high-entropy value and enter it on the setup form.
OMNI_SETUP_TOKEN=

# Non-loopback http:// public URLs are rejected unless this is explicitly true.
# Use only for local development or tightly controlled private testing.
OMNI_ALLOW_INSECURE_HTTP=false

# Database backend. Leave unset (or "sqlite") to use the zero-config SQLite file
# on the named volume. To use Postgres, set the driver to "postgres" and provide
# a connection URL; the URL holds credentials, so keep it in this .env only.
# From the container, reach a Postgres published on the host via the host IP.
#OMNI_DATABASE_DRIVER=postgres
#OMNI_DATABASE_URL=postgres://appuser:PASSWORD@192.168.68.34:5432/appdb?sslmode=disable

# HTTP server resource limits.
OMNI_SERVER_READ_HEADER_TIMEOUT=10s
OMNI_SERVER_READ_TIMEOUT=30s
OMNI_SERVER_WRITE_TIMEOUT=30s
OMNI_SERVER_IDLE_TIMEOUT=120s
OMNI_SERVER_MAX_HEADER_BYTES=1048576

# Secure cookies are required for HTTPS public URLs.
OMNI_COOKIES_SECURE=true

# Live security settings are seeded from these values on first start and can be
# edited later from Admin > Settings.
OMNI_SECURITY_TOKEN_TTL=15m
OMNI_SECURITY_REFRESH_TOKEN_TTL=720h
OMNI_SECURITY_MAX_FAILED_LOGINS=5
OMNI_SECURITY_LOCKOUT_DURATION=15m
OMNI_SECURITY_RATE_LIMIT_WINDOW=15m
OMNI_SECURITY_LOGIN_IP_MAX_ATTEMPTS=20
OMNI_SECURITY_PASSWORD_VERIFY_CONCURRENCY=4
OMNI_SECURITY_MAX_LOGIN_USERNAME_BYTES=320
OMNI_SECURITY_MAX_LOGIN_PASSWORD_BYTES=1024
OMNI_SECURITY_ALLOW_LOOPBACK_HTTP_REDIRECTS=true
OMNI_SECURITY_PASSWORD_MIN_LENGTH=12
OMNI_SECURITY_REQUIRE_UPPER=false
OMNI_SECURITY_REQUIRE_LOWER=false
OMNI_SECURITY_REQUIRE_NUMBER=true
OMNI_SECURITY_REQUIRE_SYMBOL=false
OMNI_SECURITY_SESSION_LIFETIME=12h
OMNI_SECURITY_SESSION_IDLE_TIMEOUT=0
OMNI_UPLOADS_MAX_LOGO_BYTES=524288

# Empty disables /metrics. Set a strong token and scrape with:
# Authorization: Bearer $OMNI_METRICS_TOKEN
OMNI_METRICS_TOKEN=

# --- LDAP / Active Directory authentication backend (optional) ---
# When enabled, users sign in with their directory credentials; Omni binds to
# verify them and just-in-time provisions a local mirror account. Off by default.
# The bind password is a secret and is read only from here / config, never the
# web-editable settings.
#OMNI_LDAP_ENABLED=true
#OMNI_LDAP_PRESET=activedirectory          # activedirectory | openldap
#OMNI_LDAP_URL=ldaps://dc1.example.com:636 # ldap:// or ldaps://
#OMNI_LDAP_START_TLS=false                 # upgrade a ldap:// connection to TLS
#OMNI_LDAP_BIND_DN=cn=svc-omni,ou=svc,dc=example,dc=com   # empty => anonymous search
#OMNI_LDAP_BIND_PASSWORD=                  # SECRET
#OMNI_LDAP_BASE_DN=ou=people,dc=example,dc=com
#OMNI_LDAP_ADMIN_GROUP_DN=cn=omni-admins,ou=groups,dc=example,dc=com  # members become admins
# Filters/attributes default from the preset; override only if your schema differs:
#OMNI_LDAP_USER_FILTER=(&(objectClass=user)(sAMAccountName=%s))
#OMNI_LDAP_ATTR_USERNAME=sAMAccountName
#OMNI_LDAP_ATTR_EMAIL=mail
#OMNI_LDAP_ATTR_DISPLAY_NAME=displayName
#OMNI_LDAP_GROUP_FILTER=(&(objectClass=group)(member=%s))
#OMNI_LDAP_CA_CERT_FILE=                   # PEM bundle for a private CA
#OMNI_LDAP_INSECURE_SKIP_VERIFY=false      # labs only; never in production
#OMNI_LDAP_TIMEOUT=10s
# Write management: create/edit/delete/set-password for directory users from the
# admin panel (directory stays canonical). Requires a bind_dn with write access.
#OMNI_LDAP_MANAGE_ENABLED=true
#OMNI_LDAP_PEOPLE_BASE_DN=ou=people,dc=example,dc=com   # empty => base_dn
#OMNI_LDAP_RDN_ATTR=uid                    # empty => attr_username
#OMNI_LDAP_USER_OBJECT_CLASSES=top,person,organizationalPerson,inetOrgPerson

# --- Logging ---
# Verbosity applies to stdout and to omnilog shipping alike.
# OMNI_LOG_LEVEL: debug | info | warn | error (default info).
# OMNI_LOG_HTTP_REQUESTS: per-request access logging — all | errors | off.
#   Default "errors" logs only 4xx/5xx so successful traffic doesn't flood the
#   logs; set "all" for a full access log, "off" to silence request logs.
#OMNI_LOG_LEVEL=info
#OMNI_LOG_HTTP_REQUESTS=errors

# --- Log shipping to omnilog (optional) ---
# When enabled, structured logs are shipped to omnilog's /api/v1/ingest in
# addition to stdout. Best-effort and non-blocking. The API key is a secret.
#OMNI_LOGGING_ENABLED=true
#OMNI_LOGGING_URL=http://omnilog.example.local:8080
#OMNI_LOGGING_API_KEY=                     # SECRET (matches an OMNILOG_INGEST_KEYS entry)
#OMNI_LOGGING_SERVICE=omni-identity
